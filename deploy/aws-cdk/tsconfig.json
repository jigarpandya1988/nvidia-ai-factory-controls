{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["es2020"],
    "declaration": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "outDir": "./dist",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "aws-cdk-lib": ["./node_modules/aws-cdk-lib"],
      "aws-cdk-lib/*": ["./node_modules/aws-cdk-lib/*"],
      "constructs": ["./node_modules/constructs"]
    }
  },
  "include": ["bin/**/*.ts", "lib/**/*.ts", "../../tests/typescript/**/*.ts"],
  "exclude": ["node_modules", "dist", "cdk.out"]
}
