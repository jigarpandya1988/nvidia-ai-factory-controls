# =============================================================================
# NATS Edge Gateway — Environment Variables
# =============================================================================
# Copy to .env and fill in production values.
# For local/dev: leave passwords empty (NATS auth is user-based, empty = no check)
# For production: set passwords and enable TLS in nats-server.conf
# =============================================================================

# NATS user passwords (must match nats-server.conf)
NATS_IPC_POWER_PW=
NATS_IPC_COOLING_PW=
NATS_IPC_ENVIRONMENT_PW=
NATS_IPC_SAFETY_PW=
NATS_CLOUD_PW=
NATS_GRAFANA_PW=

# AWS IoT endpoint (from: aws iot describe-endpoint --endpoint-type iot:Data-ATS)
AWS_IOT_ENDPOINT=

# AWS region
AWS_REGION=us-west-2

# Grafana admin password
GRAFANA_PASSWORD=changeme

# ─── Production TLS ──────────────────────────────────────────────────
# To enable TLS:
# 1. Uncomment TLS section in nats-server.conf
# 2. Place certs in ./certs/nats/ directory
# 3. Change all client URLs from nats:// to tls://
# 4. Set NATS_URL=tls://nats:4222 in bridge environments
